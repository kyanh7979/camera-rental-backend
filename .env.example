# ============================================
# CAMERA RENTAL - ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env and fill in REAL values
# DO NOT commit .env to version control
# ============================================

# ============================================
# SPRING BOOT ACTIVE PROFILE
# ============================================
# Options: dev, prod
# Default: (none - uses application.yml defaults)
SPRING_PROFILES_ACTIVE=prod

# ============================================
# DATABASE CONFIGURATION (REQUIRED)
# ============================================
# Local: jdbc:mysql://localhost:3306/camera_rental
# AWS RDS: jdbc:mysql://your-rds-endpoint.rds.amazonaws.com:3306/camera_rental
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/camera_rental?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=Asia/Ho_Chi_Minh&allowPublicKeyRetrieval=true&characterEncoding=UTF-8
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=your_database_password_here

# ============================================
# EMAIL/MAIL CONFIGURATION (REQUIRED)
# ============================================
# Gmail SMTP settings
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=your_email@gmail.com
# Use App Password from Google Account > Security > 2-Step Verification > App Passwords
SPRING_MAIL_PASSWORD=your_gmail_app_password_here

# ============================================
# JWT CONFIGURATION (REQUIRED)
# ============================================
# Generate a secure random string (min 64 characters for HS512)
# Example: openssl rand -base64 64
APP_JWT_SECRET=generate_a_secure_random_string_at_least_64_characters_long_here
APP_JWT_EXPIRATION_MS=604800000

# ============================================
# TELEGRAM BOT CONFIGURATION (REQUIRED FOR NOTIFICATIONS)
# ============================================
# Get bot token from @BotFather on Telegram
APP_TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Get chat ID from @userinfobot or your bot chat
APP_TELEGRAM_CHAT_ID=your_telegram_chat_id_here
APP_TELEGRAM_WARNING_ENABLED=true
APP_TELEGRAM_CHECK_INTERVAL_MS=300000

# ============================================
# CORS CONFIGURATION
# ============================================
# Production frontend domain (comma-separated)
APP_CORS_ALLOWED_ORIGINS=https://your-domain.com,http://localhost:5173,http://localhost:3000

# ============================================
# APPLICATION BASE URL
# ============================================
# Your production frontend URL
APP_BASE_URL=https://your-domain.com

# ============================================
# PAYOS PAYMENT CONFIGURATION (REQUIRED FOR PAYMENTS)
# ============================================
# Get credentials from PayOS dashboard: https://payos.vn
PAYOS_API_KEY=your_payos_api_key_here
PAYOS_CLIENT_ID=your_payos_client_id_here
PAYOS_CHECKSUM_KEY=your_payos_checksum_key_here

# PayOS Return/Cancel URLs (frontend pages)
PAYOS_RETURN_URL=https://your-domain.com/payment-success
PAYOS_CANCEL_URL=https://your-domain.com/payment-cancel

# PayOS Webhook URL (must be HTTPS for production)
# Configure this in PayOS dashboard AND set here
PAYOS_WEBHOOK_URL=https://your-domain.com/api/payment/webhook

# ============================================
# AWS S3 CONFIGURATION (REQUIRED FOR FILE UPLOADS)
# ============================================
# Get from AWS IAM > Users > Security credentials
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_REGION=ap-southeast-2
AWS_S3_BUCKET_NAME=your-s3-bucket-name
# Public base URL for S3 files (can use CloudFront or S3 direct)
AWS_S3_PUBLIC_BASE_URL=https://your-bucket.s3.ap-southeast-2.amazonaws.com
AWS_S3_MAX_SIZE_BYTES=10485760

# ============================================
# LOCAL STORAGE CONFIGURATION (FALLBACK)
# ============================================
APP_STORAGE_LOCAL_DIR=uploads
APP_STORAGE_LOCAL_BASE_URL=https://your-domain.com/uploads

# ============================================
# GEMINI AI CONFIGURATION (REQUIRED FOR AI CHAT)
# ============================================
# Get API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# Optional: Override model
# GEMINI_MODEL=gemini-2.0-flash
